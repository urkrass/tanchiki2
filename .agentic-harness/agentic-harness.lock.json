      },
      {
        "kind": "validation_memory",
        "path": ".agentic-harness/memory/validation-memory.json",
        "required": true
      },
      {
        "kind": "closeout_memory",
        "path": ".agentic-harness/memory/closeout-memory.json",
        "required": true
      }
    ],
    "memory_ledger_path": ".agentic-harness/memory-ledger.json",
