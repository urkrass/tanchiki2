{
  "name": "tanchiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build:shared": "tsc -p packages/shared/tsconfig.json",
    "build": "npm run build:shared && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "game:smoke": "vitest run src/game/game.test.ts",
    "server:dev": "npm run build:shared && node packages/server/server.mjs",
    "server:start": "node packages/server/server.mjs",
    "server:smoke": "npm run build:shared && node packages/server/teamBattleRoom.integration.mjs",
    "online:lab:quick": "npm run build:shared && node qa/online/synthetic-lab.mjs --matches 3 --seed 20260722",
    "online:lab:realtime": "npm run build:shared && node qa/online/synthetic-lab.mjs --matches 1 --seed 20260722 --realtime",
    "online:lab:soak": "npm run build:shared && node qa/online/synthetic-lab.mjs --matches 100 --seed 20260722 --mode seeded",
    "online:browser:four-context": "npm run build:shared && node qa/playwright/online-four-context-smoke.mjs",
    "online:browser:tablet-entry": "npm run build:shared && node qa/playwright/online-tablet-entry-smoke.mjs",
    "online:fault:quick": "npm run build:shared && node qa/online/toxiproxy/fault-lab.mjs --profile mixed --matches 1 --seed 20260722",
    "online:fault:outage-soak": "npm run build:shared && node qa/online/toxiproxy/outage-soak.mjs",
    "assets:validate": "node scripts/generate-vehicle-atlas.mjs --check",
    "visual:contrast": "node qa/playwright/contrast-check.mjs",
    "visual:tank-carousel": "node qa/playwright/tank-class-carousel-smoke.mjs",
    "visual:p7-signal-scar": "node qa/playwright/p7-signal-scar-smoke.mjs",
    "visual:f1-spatial-hearing": "node qa/playwright/p7-signal-scar-smoke.mjs --out-root output/f1-spatial-hearing/smoke",
    "harness:validate": "node ./.agentic-harness/harness-wrapper.mjs validate",
    "harness:smoke": "node ./.agentic-harness/harness-wrapper.mjs smoke",
    "harness:review-warden:product-repo": "node ./.agentic-harness/product-review-warden-check.mjs",
    "harness:deep-agent:stub-runtime": "node ./.agentic-harness/deep-agents/run-stub-runtime.mjs --profile .agentic-harness/deep-agents/runtime-profile.json --scenario .agentic-harness/deep-agents/scenarios/polish-planning.json --output .agentic-harness/deep-agents/outputs/polish-plan-v1.json --plan-output docs/planning/tanchiki2-polish-plan-v1.md --stdout --compact --trace --check",
    "harness:reviewer-app:dry-run": "node ./.agentic-harness/harness-wrapper.mjs reviewer-app-dry-run",
    "harness:attended-v2:lifecycle-trace-smoke": "node ./.agentic-harness/harness-wrapper.mjs attended-v2-lifecycle-trace-smoke",
    "validate": "npm run assets:validate && npm run test && npm run build && npm run server:smoke && npm run harness:validate && npm run harness:smoke && npm run harness:reviewer-app:dry-run && npm run harness:attended-v2:lifecycle-trace-smoke"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "ws": "8.21.1"
  },
  "dependencies": {
    "@colyseus/sdk": "0.17.43",
    "colyseus": "0.17.10"
  }
}
